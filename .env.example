# Copy to .env.local and fill in values from the team (never commit real secrets).
# cp .env.example .env.local

# --- Required for local dev ---

# Pidro backend API (auth, profile, token refresh)
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# NextAuth session encryption — generate with: openssl rand -base64 32
AUTH_SECRET=

# DatoCMS read token for marketing pages, blog, and home content
NEXT_DATOCMS_API_TOKEN=

# Site URL used for auth redirects (defaults to http://localhost:3000 if unset)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Optional (password reset flows) ---

# Backend endpoints for reset-password pages; omit if you are not working on that feature
PIDRO_API_VALIDATE_RESET_TOKEN_URL=
PIDRO_API_SET_NEW_PASSWORD_URL=
